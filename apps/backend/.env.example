# Server Configuration
PORT=3000
NODE_ENV=development

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Service role key bypasses RLS - used for admin operations
SUPABASE_SERVICE_KEY=your-service-role-key

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# Access token expires in 15 minutes
ACCESS_TOKEN_EXPIRES_IN=15m
# Refresh token expires in 7 days
REFRESH_TOKEN_EXPIRES_IN=7d

# OpenWA Configuration
# URL of the Railway-deployed OpenWA backend instance
# REQUIRED: Replace with your OpenWA Railway deployment URL
OPENWA_URL=https://your-openwa-app.up.railway.app
# API key for OpenWA (if authentication is enabled on OpenWA)
OPENWA_API_KEY=your-openwa-api-key

# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=debug
