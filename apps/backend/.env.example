# Server Configuration
PORT=3000
NODE_ENV=development

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Service role key bypasses RLS - used for admin operations
SUPABASE_SERVICE_KEY=your-service-role-key

# OpenWA Configuration
# Railway Private URL for service-to-service communication (use internal URL)
# In Railway, services can communicate via private networking using .railway.internal domains
OPENWA_URL=http://openwa.railway.internal
# API key for OpenWA (if authentication is enabled on OpenWA)
OPENWA_API_KEY=your-openwa-api-key

# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=debug
