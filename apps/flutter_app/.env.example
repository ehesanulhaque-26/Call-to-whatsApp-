# API Configuration
# SaaS Backend REST API URL (must include /api/v1 prefix)
API_BASE_URL=https://your-backend-url.com/api/v1

# WebSocket URL for real-time session events
# Usually same as backend URL with /openwa namespace
WS_URL=https://your-backend-url.com/openwa

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# App Configuration
APP_VERSION=1.0.0
DEBUG=false
